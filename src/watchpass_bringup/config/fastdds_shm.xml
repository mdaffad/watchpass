<?xml version="1.0" encoding="UTF-8"?>
<!--
  Fast DDS profile that guarantees the shared-memory / data-sharing (zero-copy)
  path for Watchpass on a single host.

  Export it before launching so rmw_fastrtps_cpp picks it up:
    export FASTRTPS_DEFAULT_PROFILES_FILE=$(ros2 pkg prefix watchpass_bringup)/share/watchpass_bringup/config/fastdds_shm.xml
  The stream.launch.py file sets this for you.

  Notes:
    * Data-sharing (the zero-copy loan mechanism) requires a PREALLOCATED history
      memory policy and a bounded/"plain" message type. WatchFrame satisfies both.
    * The shared-memory transport is added explicitly and sized generously so a
      2.7 MB WatchFrame plus history depth fits in the segment.
    * The default UDP transport is kept for discovery so this still works across
      hosts (data then falls back to UDP; loaned messages become plain copies).
-->
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <profiles>
    <transport_descriptors>
      <transport_descriptor>
        <transport_id>watchpass_shm</transport_id>
        <type>SHM</type>
        <!-- 128 MiB: room for several in-flight 2.7 MB frames. -->
        <segment_size>134217728</segment_size>
      </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="watchpass_participant" is_default_profile="true">
      <rtps>
        <userTransports>
          <transport_id>watchpass_shm</transport_id>
        </userTransports>
        <!-- Keep the builtin UDP transport too (discovery + cross-host). -->
        <useBuiltinTransports>true</useBuiltinTransports>
      </rtps>
    </participant>

    <data_writer profile_name="watchpass_writer" is_default_profile="true">
      <qos>
        <data_sharing>
          <kind>AUTOMATIC</kind>
        </data_sharing>
      </qos>
      <historyMemoryPolicy>PREALLOCATED_WITH_REALLOC</historyMemoryPolicy>
    </data_writer>

    <data_reader profile_name="watchpass_reader" is_default_profile="true">
      <qos>
        <data_sharing>
          <kind>AUTOMATIC</kind>
        </data_sharing>
      </qos>
      <historyMemoryPolicy>PREALLOCATED_WITH_REALLOC</historyMemoryPolicy>
    </data_reader>
  </profiles>
</dds>
